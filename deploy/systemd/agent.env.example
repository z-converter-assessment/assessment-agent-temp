# Assessment Agent — environment template
# Copy to /etc/assessment-agent/agent.env (chmod 600, owned by assessment-agent)
# and edit. Secret values (PASS) should come from a separate drop-in
# (agent.env.local) populated by your secret-store / Ansible vault.

# --- Broker connection (collector) --------------------------------------
# RABBITMQ_HOST: site-specific broker address. Left empty on purpose — the
# operator supplies it at install time (env-setup.sh prompts / RABBITMQ_HOST=
# preset), it is NOT baked into the template.
RABBITMQ_HOST=
RABBITMQ_PORT=5672
RABBITMQ_VHOST=assessment
RABBITMQ_USER=assessment
# RABBITMQ_PASS=  -- inject via agent.env.local

# --- TLS ---------------------------------------------------------------
RABBITMQ_TLS_ENABLED=false
RABBITMQ_TLS_CA_PATH=/etc/assessment-agent/ca.pem
RABBITMQ_TLS_VERIFY_PEER=true
RABBITMQ_TLS_VERIFY_HOSTNAME=true
# RABBITMQ_TLS_CERT_PATH=/etc/assessment-agent/client.pem    # optional mTLS
# RABBITMQ_TLS_KEY_PATH=/etc/assessment-agent/client.key

# --- Heartbeat ---------------------------------------------------------
RABBITMQ_HEARTBEAT_SEC=60
RABBITMQ_CONFIRM_TIMEOUT_SEC=5

# --- Exchange / routing keys (collector) -------------------------------
RABBITMQ_EXCHANGE=assessment
RABBITMQ_ROUTING_KEY_INVENTORY=server.inventory
RABBITMQ_ROUTING_KEY_METRICS=server.metrics
RABBITMQ_ROUTING_KEY_ERROR=server.error

# --- Collector cadence -------------------------------------------------
AGENT_INTERVAL_SEC=60
AGENT_INVENTORY_REFRESH_SEC=3600

# --- Drain (SIGTERM behavior) ------------------------------------------
# AGENT_DRAIN_GRACE_SEC=600          # wait this long for install to finish on its own
# AGENT_DRAIN_TERM_SEC=30            # +SIGTERM, then this long, then SIGKILL
# AGENT_DRAIN_PUBLISH_SEC=180        # if install done but publish stuck, give up after this

# --- Worker (task.install) — leave RABBITMQ_WORKER_USER unset to disable
RABBITMQ_WORKER_USER=assessment
# RABBITMQ_WORKER_PASS=  -- inject via agent.env.local
WORKER_TASK_EXCHANGE=assessment.tasks
WORKER_TASK_QUEUE_PREFIX=agent.tasks
WORKER_TASK_RESULT_KEY=task.result

# --- Worker policy -----------------------------------------------------
# Empty WORKER_DOWNLOAD_ALLOWED_HOSTS = block all downloads = worker disabled.
WORKER_DOWNLOAD_ALLOWED_HOSTS=192.168.3.92,192.168.3.94
WORKER_STATE_DIR=/var/lib/agent-worker
WORKER_TMP_DIR=/tmp
WORKER_DONE_RETENTION_SEC=604800           # 7 days
WORKER_DISK_RESERVE_MB=50
WORKER_INSTALL_MEM_LIMIT_MB=2048
WORKER_INSTALL_FSIZE_LIMIT_MB=5120
WORKER_INSTALL_NOFILE=4096
