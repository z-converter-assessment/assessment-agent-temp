# 줄바꿈/바이너리 취급 정본.
# objcopy(`ld -r -b binary`)로 Linux 바이너리에 embed되는 셸/유닛 스크립트는 반드시 LF —
# CRLF 오염 시 embed된 스크립트가 /bin/sh 에서 깨진다. 그래서 텍스트 자산을 LF로 고정한다.

# 소스/스크립트/문서 — LF 정규화.
*.c      text eol=lf
*.h      text eol=lf
*.sh     text eol=lf
*.py     text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.service text eol=lf
Makefile text eol=lf

# 확장자 없는 embed 대상(SysV init 스크립트 등) — LF 고정.
deploy/sysv/assessment-agent text eol=lf

# 빌드 산출물 — 바이너리.
*.exe    binary
*.res    binary
*.o      binary
*.a      binary
